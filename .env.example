# Anthropic API key (required)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Gmail OAuth2 credentials file path (required)
# Download from Google Cloud Console -> APIs & Services -> Credentials
GMAIL_CREDENTIALS_FILE=credentials.json

# Path to store Gmail OAuth token (generated on first run)
GMAIL_TOKEN_FILE=token.json

# Email categories (comma-separated, customize as needed)
EMAIL_CATEGORIES=仕事,プロジェクト,請求・支払い,ニュースレター,個人,スパム・広告,その他

# Report output directory
REPORT_OUTPUT_DIR=reports

# Days of email to fetch per run (default: 1 = today only)
FETCH_DAYS=1

# Claude model to use for classification and summarization
CLAUDE_MODEL=claude-sonnet-4-6
