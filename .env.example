# ===== Anthropic =====
# Claude API キー（必須）
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 使用するモデル
CLAUDE_MODEL=claude-sonnet-4-6

# ===== Gmail =====
# Google Cloud Console からダウンロードした認証ファイルのパス（必須）
GMAIL_CREDENTIALS_FILE=credentials.json

# OAuth トークン保存先（初回実行時に自動生成）
GMAIL_TOKEN_FILE=token.json

# ===== メール分類 =====
# カテゴリ（カンマ区切り。空白の場合はデフォルトを使用）
EMAIL_CATEGORIES=仕事,プロジェクト,請求・支払い,ニュースレター,個人,スパム・広告,その他

# 取得日数（デフォルト: 1 = 過去 24 時間）
FETCH_DAYS=1

# ===== 出力 =====
# レポート保存ディレクトリ
REPORT_OUTPUT_DIR=reports

# ===== LINE Notify =====
# LINE Notify アクセストークン（--notify フラグを使う場合は必須）
# 取得方法: https://notify-bot.line.me/my/
LINE_NOTIFY_TOKEN=your_line_notify_token_here
