# ===== Anthropic =====
# Claude API キー（必須）
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 使用するモデル
CLAUDE_MODEL=claude-sonnet-4-6

# ===== Gmail =====
# Google Cloud Console からダウンロードした認証ファイルのパス（必須）
GMAIL_CREDENTIALS_FILE=credentials.json

# OAuth トークン保存先（初回実行時に自動生成）
GMAIL_TOKEN_FILE=token.json

# ===== メール分類 =====
# カテゴリ（カンマ区切り。空白の場合はデフォルトを使用）
EMAIL_CATEGORIES=仕事,プロジェクト,請求・支払い,ニュースレター,個人,スパム・広告,その他

# 取得日数（デフォルト: 1 = 過去 24 時間）
FETCH_DAYS=1

# ===== 出力 =====
# レポート保存ディレクトリ
REPORT_OUTPUT_DIR=reports

# ===== LINE Messaging API =====
# Channel Access Token（LINE Developers コンソール > Messaging API > Channel access token）
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# 送信先 ID（自分の User ID: Uxxxxxxxx、またはグループ ID: Cxxxxxxxx）
# 取得方法: SETUP.md の「LINE 送信先 ID の確認」を参照
LINE_RECIPIENT_ID=Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
